# ── Backend environment variables ──────────────────────────────────────────
# Copy to `.env` and adjust. NEVER commit a real `.env` (see .gitignore).

# Database connection string.
#   Local (zero-config) :  sqlite:///./inventory.db
#   Docker Compose      :  postgresql+psycopg2://inventory:CHANGE_ME@db:5432/inventory
#   Render/Railway/Fly  :  use the connection string the platform gives you
DATABASE_URL=postgresql+psycopg2://inventory:CHANGE_ME@db:5432/inventory

# Comma-separated list of allowed frontend origins, or "*" for all.
# In production set this to your deployed frontend URL, e.g.
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=*

# Products at or below this quantity are flagged as "low stock".
LOW_STOCK_THRESHOLD=10

# Seed demo data on first startup when the database is empty (true/false).
SEED_DATA=true

# Set to true for verbose / development behaviour.
DEBUG=false
