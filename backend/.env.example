# Copy to .env and adjust. Don't commit a real .env.

# SQLite for local dev (no setup), Postgres for Docker/production:
#   sqlite:///./inventory.db
#   postgresql+psycopg2://inventory:CHANGE_ME@db:5432/inventory
DATABASE_URL=postgresql+psycopg2://inventory:CHANGE_ME@db:5432/inventory

# Allowed frontend origins ("*" or a comma-separated list).
CORS_ORIGINS=*

# Quantity at or below this is flagged as low stock.
LOW_STOCK_THRESHOLD=10

# Seed demo data when the database is empty.
SEED_DATA=true

DEBUG=false
