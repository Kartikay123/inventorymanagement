# Only VITE_-prefixed vars reach the browser bundle.

# Where the app sends API calls.
#   /api  -> proxied to the backend (Docker and dev), no CORS
#   or the backend's full URL for a split deploy, e.g. https://your-backend.onrender.com
VITE_API_BASE_URL=/api

# Dev only: where Vite proxies /api during `npm run dev`.
VITE_DEV_API_TARGET=http://localhost:8000
