# ── Frontend environment variables (Vite) ──────────────────────────────────
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# Base URL the frontend uses to reach the backend API.
#   Local dev / Docker  :  /api   (proxied to the backend — no CORS, no rebuild)
#   Vercel / Netlify    :  https://your-backend.onrender.com
VITE_API_BASE_URL=/api

# Dev-server only: where Vite proxies "/api" during `npm run dev`.
VITE_DEV_API_TARGET=http://localhost:8000
