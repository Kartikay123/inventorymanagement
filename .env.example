# ── Root environment for docker-compose ─────────────────────────────────────
# Copy to `.env` (which is gitignored) and change the password before any real use:
#   cp .env.example .env

# PostgreSQL credentials (used by the db, backend connection string).
POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=inventory

# Host ports to publish.
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Backend behaviour.
# In production set CORS_ORIGINS to your deployed frontend origin(s), e.g.
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=*
LOW_STOCK_THRESHOLD=10
SEED_DATA=true
