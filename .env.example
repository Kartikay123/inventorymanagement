# Copy to .env and set a Postgres password before any real use.

POSTGRES_USER=inventory
POSTGRES_PASSWORD=change_me
POSTGRES_DB=inventory

# Host ports
BACKEND_PORT=8000
FRONTEND_PORT=8080

# In production set CORS_ORIGINS to the frontend URL instead of "*".
CORS_ORIGINS=*
LOW_STOCK_THRESHOLD=10
SEED_DATA=true
